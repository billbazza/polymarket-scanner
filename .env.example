# Polymarket Scanner Configuration
# Copy to .env and fill in your values

# Claude API key for brain module (probability estimation)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot (optional, for alerts)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polygon RPC (optional, for Tier 3 execution)
# Get from: https://www.alchemy.com/polygon
ALCHEMY_API_KEY=

# Polymarket private key (optional, for live trading)
# WARNING: Keep this secret. Never commit with a real key.
POLYMARKET_PRIVATE_KEY=

# Perplexity API key (optional, for real-time research during brain validation)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
