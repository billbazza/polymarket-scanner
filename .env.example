# Polymarket Scanner Configuration
# Copy to .env and fill in your values

# Brain provider selection:
# - auto      = prefer Anthropic while credits work, then fall forward to OpenAI
# - anthropic = only use Anthropic
# - openai    = only use OpenAI
BRAIN_PROVIDER=auto

# Anthropic API key for the current brain primary
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for Codex/OpenAI brain fallback or cutover
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional OpenAI-compatible base URL override for Codex/OpenAI cutover testing
OPENAI_BASE_URL=

# Optional model overrides for staged migration / provider tuning
BRAIN_ANTHROPIC_MODEL=
BRAIN_ANTHROPIC_COMPLEX_MODEL=
BRAIN_OPENAI_MODEL=
BRAIN_OPENAI_COMPLEX_MODEL=

# Telegram bot (optional, for alerts)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polygon RPC (optional, for Tier 3 execution)
# Get from: https://www.alchemy.com/polygon
ALCHEMY_API_KEY=

# Polymarket private key (optional, for live trading)
# WARNING: Keep this secret. Never commit with a real key.
POLYMARKET_PRIVATE_KEY=

# Opt-in weather exact-temperature sub-strategy.
# Enabled scan support stays off by default and autonomy paper auto-trading is a separate flag.
WEATHER_EXACT_TEMP_ENABLED=0
WEATHER_EXACT_TEMP_AUTOTRADE=0

# Perplexity API key (optional, for real-time research during brain validation)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
